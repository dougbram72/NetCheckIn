# NetCheckin Docker environment

# App port exposed on the host machine.
NETCHECKIN_PORT=3100

# Container bind host inside Docker. Usually leave this at 0.0.0.0.
NETCHECKIN_HOST=0.0.0.0

# Python binary inside the container.
NETCHECKIN_PYTHON=python3

# Ollama access from Docker:
# Windows / macOS Docker Desktop:
# OLLAMA_HOST=http://host.docker.internal:11434
#
# Linux Docker with host-gateway support:
# OLLAMA_HOST=http://host.docker.internal:11434
#
# If host.docker.internal is unavailable on your Linux setup, replace it with
# your host machine IP on the Docker bridge/network.
OLLAMA_HOST=http://host.docker.internal:11434

# Optional: pin a specific local Ollama model.
# Example:
# OLLAMA_MODEL=gemma3:4b
OLLAMA_MODEL=
